; Declare the five top level accounts in your preferred language/capitalisation;
; their types (to make reports like bs and is work); and their display order.
; Write at least 2 spaces before the ; comments.
account assets       ; type:A, money you own.
account liabilities  ; type:L, money you owe to others
account equity       ; type:E, equal to A - L
account revenues     ; type:R, revenues/income categories
account expenses     ; type:X, expense categories

alias assets = Assets
alias liabilities = Liabilities
alias equity = Equity
alias revenues = Income
alias expenses = Expenses

; Use an amount format that's easily compatible w/ Python & R
commodity 1000.00 EUR
commodity 1000.000000 BTC
commodity 1000. "CW8"
commodity 1000.00 USDC
commodity 1000. DCAM
commodity 1000.00 "CL2"

include /workspaces/accounting/src/hledger/prices/cw8.prices
include /workspaces/accounting/src/hledger/prices/dcam.prices
include /workspaces/accounting/src/hledger/prices/cl2.prices
include /workspaces/accounting/src/hledger/prices/btc.prices
include /workspaces/accounting/src/hledger/prices/usdc.prices

